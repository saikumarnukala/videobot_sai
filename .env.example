# API Keys
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.0-flash"  # Optional: Gemini model name
GITHUB_TOKEN="your_github_token_here"  # For GitHub Copilot Models API
GITHUB_COPILOT_MODEL="gpt-4o"  # Optional: Model for GitHub Copilot
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"  # Optional: Groq model
PEXELS_API_KEY="your_pexels_api_key_here"
JAMENDO_CLIENT_ID="your_jamendo_client_id_here"  # Get FREE at: https://developer.jamendo.com/
JAMENDO_ALLOWED_TRACK_IDS=""                     # Optional: comma-separated Jamendo track IDs (only these tracks will be used)
ELEVENLABS_API_KEY="your_elevenlabs_api_key_here"
ELEVENLABS_VOICE_ID=""  # Optional: ElevenLabs voice ID
ELEVENLABS_MODEL_ID="eleven_multilingual_v2"  # Optional: ElevenLabs model

# YouTube Upload Settings
YOUTUBE_CATEGORY_ID="22"       # 22 is People & Blogs, 27 is Education
YOUTUBE_PRIVACY_STATUS="private" # 'public', 'private', or 'unlisted'
YOUTUBE_PRIVACY="private"      # Alternative privacy setting

# Content Configuration
VIDEO_TOPIC="motivational quotes for success"
VIDEO_LENGTH_SECONDS="85"
UPLOAD_TO_YOUTUBE="False"            # Set to True to enable YouTube uploading
BGM_VOLUME="0.08"                    # Volume of the background music (0.0 to 1.0)
RENDER_PRESET="medium"               # FFmpeg render preset (ultrafast, superfast, veryfast, faster, fast, medium, slow, slower, veryslow)

# Audio Configuration (Deepgram Aura-2)
DEEPGRAM_API_KEY="your_deepgram_api_key_here"  # Get at https://console.deepgram.com/
DEEPGRAM_VOICE=""                                # Optional: fixed voice (e.g. aura-2-thalia-en)
DEEPGRAM_VOICES=""                               # Optional: comma-separated daily rotation pool
DEEPGRAM_SPEED="1.22"                            # Shorts pacing: 1.0=normal, 1.22=fast (0.7–1.5)
MAX_RETRIES="3"                                  # Retry count for audio generation
